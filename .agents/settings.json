{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh auth *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git clean *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git branch -D *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "life-rag"
  ],
  "mcpServers": {
    "life-rag": {
      "command": "/home/shun/.local/bin/uv",
      "args": [
        "--directory",
        "/home/shun/life-rag-mcp",
        "run",
        "python",
        "-m",
        "life_rag_mcp.server"
      ]
    }
  }
}
