#!/bin/bash
# life-rag-mcp: Incremental index update after commit
# Runs in background to avoid slowing down git operations
# Supports both uv and pip+venv

REPO_ROOT="$(git rev-parse --show-toplevel)"
RAG_DIR="$REPO_ROOT/rag-mcp"
VENV_DIR="$RAG_DIR/.venv"
TARGET_DIRS="journal/|knowledge/|thoughts/|profile/|works/|references/"

# Ensure Ollama runner symlink (see setup.sh for details)
if command -v ollama &>/dev/null && ! command -v serve &>/dev/null; then
    ollama_bin="$(command -v ollama)"
    ln -sf "$ollama_bin" /usr/local/bin/serve 2>/dev/null || \
        (mkdir -p "$HOME/.local/bin" 2>/dev/null && ln -sf "$ollama_bin" "$HOME/.local/bin/serve" 2>/dev/null && export PATH="$HOME/.local/bin:$PATH")
fi

# Auto-detect Ollama URL on WSL2
if [ -f /proc/sys/fs/binfmt_misc/WSLInterop ]; then
    WIN_HOST=$(ip route show default | awk '{print $3}')
    export OLLAMA_URL="${OLLAMA_URL:-http://${WIN_HOST}:11434}"
fi

# Get changed .md files in target directories
CHANGED_FILES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -E "^($TARGET_DIRS)" | grep '\.md$')

if [ -z "$CHANGED_FILES" ]; then
    exit 0
fi

# Build args array
ARGS="--files"
for f in $CHANGED_FILES; do
    ARGS="$ARGS $f"
done

# Run indexer in background (prefer uv, fall back to venv)
if command -v uv &>/dev/null; then
    (cd "$REPO_ROOT" && uv --directory "$RAG_DIR" run life-rag-index $ARGS) &>/dev/null &
elif [ -x "$VENV_DIR/bin/life-rag-index" ]; then
    (cd "$REPO_ROOT" && "$VENV_DIR/bin/life-rag-index" $ARGS) &>/dev/null &
fi
